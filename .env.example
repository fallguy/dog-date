# Copy this file to .env and fill in real values.
#
# DEFAULT WORKFLOW IS LOCAL — run `supabase start` and use the URL/key
# it prints. Only switch to cloud values when shipping to TestFlight.

# ---- Local Supabase (default for development) ----
# Use your Mac's LAN IP (not `localhost`) so a physical iPhone can reach the API.
# Find it with: ipconfig getifaddr en0
EXPO_PUBLIC_SUPABASE_URL=http://192.168.0.0:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=PASTE-ANON-KEY-FROM-SUPABASE-START-OUTPUT

# ---- Cloud Supabase (uncomment when deploying) ----
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
