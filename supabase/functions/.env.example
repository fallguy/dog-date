# Copy this file to supabase/functions/.env and fill in real values.
# DO NOT commit the populated file (gitignored).
#
# `supabase functions serve` reads from supabase/functions/.env by default,
# so functions can access these via Deno.env.get('FAL_KEY') etc.

FAL_KEY=PASTE-YOUR-FAL-API-KEY-HERE

# How many video generations a single dog can have. Cost guardrail.
MAX_VIDEOS_PER_DOG=3
